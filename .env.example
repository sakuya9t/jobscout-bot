# ── Core ───────────────────────────────────────────────────────────────────
# Change this in production. Used to sign JWT session tokens.
JOBSCOUT_SECRET_KEY=change-me-to-a-long-random-string
JOBSCOUT_DATABASE_URL=sqlite:///./jobscout.db
JOBSCOUT_DATA_DIR=./data
# Set to 1 to mark the session cookie Secure (HTTPS-only). Enable in production
# behind TLS; leave 0 for localhost http dev.
JOBSCOUT_COOKIE_SECURE=0

# ── Logging ──────────────────────────────────────────────────────────────────
# Root log level (DEBUG/INFO/WARNING/ERROR). Logs always go to stderr; set a file
# path to also write a rotating log file.
JOBSCOUT_LOG_LEVEL=INFO
JOBSCOUT_LOG_FILE=
JOBSCOUT_LOG_MAX_BYTES=5000000
JOBSCOUT_LOG_BACKUP_COUNT=3
# Log every Ollama request/response (full prompt + completion) on the
# "jobscout.ollama" logger. Prompts include resume + job text — set to 0 to
# disable in shared/production environments.
JOBSCOUT_LOG_OLLAMA=1
# Truncate each logged prompt/response to this many chars (0 = no limit).
JOBSCOUT_LOG_OLLAMA_MAX_CHARS=4000

# ── Ollama Cloud ─────────────────────────────────────────────────────────────
# Ollama Cloud exposes the same /api/chat endpoint as a local server.
# Get a key at https://ollama.com (Settings -> Keys). For a LOCAL ollama,
# set base url to http://localhost:11434 and leave the key blank.
JOBSCOUT_OLLAMA_BASE_URL=https://ollama.com
JOBSCOUT_OLLAMA_API_KEY=
# Two models: the cheap FILTER model triages relevance (does a posting match the
# interest?); the main MODEL does the expensive resume<->role scoring only for the
# ones that pass. Set both to the same model for a local server with one model.
JOBSCOUT_OLLAMA_MODEL=gpt-oss:120b-cloud
JOBSCOUT_OLLAMA_FILTER_MODEL=deepseek-v4-flash
JOBSCOUT_OLLAMA_TIMEOUT=120

# ── Telegram (optional) ──────────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token. Users link their account
# by sending /start <link-code> to the bot (code shown on the dashboard).
JOBSCOUT_TELEGRAM_BOT_TOKEN=

# ── Scheduler ────────────────────────────────────────────────────────────────
# 24h time, server local timezone. The daily crawl+match+report runs at this hour.
JOBSCOUT_DAILY_RUN_HOUR=8
JOBSCOUT_DAILY_RUN_MINUTE=0
# Set to 0 to disable the in-process scheduler (e.g. when driving runs via cron/MCP).
JOBSCOUT_SCHEDULER_ENABLED=1

# ── Scraping ─────────────────────────────────────────────────────────────────
# NOT YET IMPLEMENTED — reserved for a future headless-browser fallback for
# JS-heavy career pages (would need the `browser` extra + `playwright install
# chromium`). Scraping currently always uses plain HTTP regardless of this flag.
JOBSCOUT_USE_BROWSER=0
JOBSCOUT_SCRAPE_USER_AGENT=Mozilla/5.0 (compatible; JobScoutBot/0.1)
JOBSCOUT_SCRAPE_MAX_POSITIONS_PER_COMPANY=40
# Per-response buffer cap (MB). Large popular boards are big — a full Greenhouse
# board with descriptions (~5MB) or a big Ashby board (~11MB) — so keep headroom.
JOBSCOUT_SCRAPE_MAX_RESPONSE_MB=32
# Google careers has no ATS API; we page its server-rendered results (20/page).
# This caps how many pages a single run pulls.
JOBSCOUT_SCRAPE_GOOGLE_MAX_PAGES=20
# Only pull postings posted/updated within this many days, to cut storage + LLM
# scoring load. Applies to dated sources (greenhouse/lever/ashby); Google careers
# and the HTML fallback have no date, so their postings are always kept. 0 = off.
JOBSCOUT_SCRAPE_MAX_AGE_DAYS=30
# Scoring runs to completion in the background after each scan (no per-run cap);
# the dashboard shows how many positions are still being evaluated. The cheap
# relevance filter is batched: one call screens this many postings at
# once (returns a verdict each), cutting the number of filter calls ~Nx.
JOBSCOUT_SCORE_FILTER_BATCH_SIZE=10
# The expensive resume/job scoring step is also batched after filtering. A value
# of 10 means up to 10 survivor postings are scored in one Ollama request.
JOBSCOUT_SCORE_BATCH_SIZE=10
